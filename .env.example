# Required: Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Required: trusted app origins
APP_BASE_URL=http://localhost:3000
ADMIN_BASE_URL=http://localhost:3000/admin

# Required: OpenAI embeddings for RAG
OPENAI_API_KEY=

# Required: OpenRouter LLM for Brand Brain and agents
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o

# Optional: Resend email delivery for access keys and invitations
RESEND_API_KEY=
EMAIL_FROM=no-reply@bextudio.test
